# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=mono
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mono_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mono:change_me_in_production@localhost:5432/mono_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_super_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── LLM ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_DEFAULT_MODEL=gpt-4o

# ─── Service URLs (used by api-gateway) ───────────────────────
AUTH_SERVICE_URL=http://localhost:8001
USERS_SERVICE_URL=http://localhost:8002
LLM_SERVICE_URL=http://localhost:8003
NOTIFICATIONS_SERVICE_URL=http://localhost:8004

# ─── Notifications ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── General ──────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000
